<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Psicóloga profesional — Evaluación psicológica, sesiones individuales y grupales. Acompañamiento terapéutico con calidez y profesionalismo.">
  <title>Psicóloga — Acompañamiento Terapéutico</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">

  <style>
    /* ============================================
       CSS CUSTOM PROPERTIES — PALETA Y TOKENS
       Tonos cálidos: terracota, beige, verde oliva,
       crema. Transmiten calma y contención.
    ============================================ */
    :root {
      --color-cream:       #FAF6F1;
      --color-beige:       #F0E6D8;
      --color-beige-dark:  #E2D3C1;
      --color-terracota:   #C4725A;
      --color-terracota-dark: #A85D47;
      --color-terracota-light: #D9A28E;
      --color-olive:       #7A8B6F;
      --color-olive-light: #94A585;
      --color-olive-dark:  #5E6E53;
      --color-brown:       #5C4A3A;
      --color-brown-light: #8B7565;
      --color-white:       #FFFFFF;
      --color-text:        #3D3129;
      --color-text-light:  #6B5D52;
      --color-text-muted:  #9A8D82;

      --font-display: 'Playfair Display', Georgia, 'Times New Roman', serif;
      --font-body:    'DM Sans', 'Segoe UI', Tahoma, sans-serif;

      --section-padding: 6rem 1.5rem;
      --container-max:   1100px;
      --radius-soft:     16px;
      --radius-pill:     999px;

      --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --transition: 0.35s var(--ease-out);
    }

    /* ============================================
       RESET Y BASE
    ============================================ */
    *, *::before, *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: var(--font-body);
      color: var(--color-text);
      background-color: var(--color-cream);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }

    .container {
      max-width: var(--container-max);
      margin: 0 auto;
      width: 100%;
    }

    /* ============================================
       ANIMACIONES — Fade-in al scroll
    ============================================ */
    .fade-in {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ============================================
       NAVEGACIÓN FIJA
    ============================================ */
    .site-nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      padding: 1rem 1.5rem;
      transition: background var(--transition), box-shadow var(--transition);
    }
    .site-nav.scrolled {
      background: rgba(250, 246, 241, 0.95);
      backdrop-filter: blur(10px);
      box-shadow: 0 2px 20px rgba(92, 74, 58, 0.08);
    }
    .nav-inner {
      max-width: var(--container-max);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--color-terracota);
      letter-spacing: 0.02em;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
    }
    .nav-links a {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-text-light);
      position: relative;
      transition: color var(--transition);
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--color-terracota);
      border-radius: 2px;
      transition: width var(--transition);
    }
    .nav-links a:hover { color: var(--color-terracota); }
    .nav-links a:hover::after { width: 100%; }

    /* Hamburger (mobile) */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 4px;
    }
    .nav-toggle span {
      width: 24px;
      height: 2px;
      background: var(--color-brown);
      border-radius: 2px;
      transition: var(--transition);
    }

    /* ============================================
       SECCIÓN 1 — HERO / PRESENTACIÓN
    ============================================ */
    .hero {
      background: var(--color-cream);
      padding: 10rem 1.5rem 6rem;
      position: relative;
      overflow: hidden;
      min-height: 100vh;
      display: flex;
      align-items: center;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -120px;
      right: -180px;
      width: 500px;
      height: 500px;
      background: radial-gradient(ellipse, var(--color-beige) 0%, transparent 70%);
      border-radius: 50%;
      opacity: 0.7;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -80px;
      left: -100px;
      width: 350px;
      height: 350px;
      background: radial-gradient(ellipse, var(--color-terracota-light) 0%, transparent 70%);
      border-radius: 50%;
      opacity: 0.2;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 2rem;
    }

    .profile-frame {
      position: relative;
      width: 220px;
      height: 220px;
    }
    .profile-frame::before {
      content: '';
      position: absolute;
      inset: -10px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-terracota-light), var(--color-olive-light));
      opacity: 0.35;
    }

    /* ========================================
       FOTO REDONDA — Reemplaza el src
    ======================================== */
    .profile-photo {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      position: relative;
      z-index: 1;
      border: 5px solid var(--color-white);
      box-shadow: 0 12px 40px rgba(92, 74, 58, 0.15);
    }

    .profile-placeholder {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: linear-gradient(145deg, var(--color-terracota-light), var(--color-olive-light));
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      z-index: 1;
      border: 5px solid var(--color-white);
      box-shadow: 0 12px 40px rgba(92, 74, 58, 0.15);
      color: var(--color-white);
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 600;
    }

    .hero-subtitle {
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-terracota);
    }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 500;
      line-height: 1.25;
      color: var(--color-brown);
      max-width: 600px;
    }
    .hero-title em {
      font-style: italic;
      color: var(--color-terracota);
    }
    .hero-text {
      font-size: 1.05rem;
      color: var(--color-text-light);
      max-width: 520px;
      line-height: 1.8;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.9rem 2.2rem;
      background: var(--color-terracota);
      color: var(--color-white);
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.95rem;
      border-radius: var(--radius-pill);
      border: none;
      cursor: pointer;
      transition: background var(--transition), transform var(--transition);
    }
    .hero-cta:hover {
      background: var(--color-terracota-dark);
      transform: translateY(-2px);
    }

    /* ============================================
       SECCIÓN 2 — SERVICIOS
    ============================================ */
    .services {
      background: var(--color-beige);
      padding: var(--section-padding);
    }

    .section-header {
      text-align: center;
      margin-bottom: 3.5rem;
    }
    .section-label {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-terracota);
      margin-bottom: 0.75rem;
      display: block;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.7rem, 4vw, 2.5rem);
      font-weight: 500;
      color: var(--color-brown);
      line-height: 1.3;
    }
    .section-title em {
      font-style: italic;
      color: var(--color-terracota);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
    }

    .service-card {
      background: var(--color-white);
      border-radius: 120px 120px var(--radius-soft) var(--radius-soft);
      padding: 3rem 1.8rem 2.2rem;
      text-align: center;
      transition: transform var(--transition), box-shadow var(--transition);
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 4px;
      border-radius: 2px;
      background: var(--color-terracota-light);
      opacity: 0;
      transition: opacity var(--transition);
    }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 48px rgba(92, 74, 58, 0.1);
    }
    .service-card:hover::before { opacity: 1; }

    .service-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 1.5rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .service-card:nth-child(1) .service-icon { background: #F8E8E2; }
    .service-card:nth-child(2) .service-icon { background: #E8EFE4; }
    .service-card:nth-child(3) .service-icon { background: #F0E6D8; }
    .service-card:nth-child(4) .service-icon { background: #E4E8EF; }

    .service-card h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: var(--color-brown);
    }
    .service-card p {
      font-size: 0.92rem;
      color: var(--color-text-light);
      line-height: 1.7;
    }

    /* ============================================
       FRANJA — AGENDAR CITA (Calendly/Doctoralia)
    ============================================ */
    .booking {
      background: var(--color-olive);
      padding: 4rem 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .booking::before {
      content: '';
      position: absolute;
      top: -60px;
      right: -60px;
      width: 200px;
      height: 200px;
      background: rgba(255,255,255,0.06);
      border-radius: 50%;
    }
    .booking-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3.5vw, 2rem);
      color: var(--color-white);
      margin-bottom: 0.75rem;
    }
    .booking-text {
      color: rgba(255,255,255,0.8);
      margin-bottom: 2rem;
      font-size: 1rem;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }
    .booking-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2.5rem;
      background: var(--color-white);
      color: var(--color-olive-dark);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 1rem;
      border-radius: var(--radius-pill);
      transition: transform var(--transition), box-shadow var(--transition);
    }
    .booking-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    /* ============================================
       SECCIÓN 3 — OTROS ESPACIOS / RECURSOS
    ============================================ */
    .resources {
      background: var(--color-cream);
      padding: var(--section-padding);
    }

    .resources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
    }

    .resource-card {
      background: var(--color-white);
      border-radius: var(--radius-soft);
      padding: 2.2rem 1.8rem;
      text-align: center;
      transition: transform var(--transition), box-shadow var(--transition);
      position: relative;
      border: 1px solid rgba(226, 211, 193, 0.5);
    }
    .resource-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 36px rgba(92, 74, 58, 0.08);
      border-color: transparent;
    }

    .resource-icon {
      width: 56px;
      height: 56px;
      margin: 0 auto 1.2rem;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-beige);
    }

    .resource-card h3 {
      font-family: var(--font-display);
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--color-brown);
    }
    .resource-card p {
      font-size: 0.88rem;
      color: var(--color-text-muted);
      line-height: 1.6;
    }

    .badge-coming {
      display: inline-block;
      background: var(--color-terracota-light);
      color: var(--color-white);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: var(--radius-pill);
      position: absolute;
      top: 1rem;
      right: 1rem;
    }

    /* ============================================
       FORMULARIO DE CONTACTO (Formspree)
    ============================================ */
    .contact {
      background: var(--color-beige);
      padding: var(--section-padding);
    }
    .contact-wrapper {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .contact-info h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--color-brown);
      margin-bottom: 0.75rem;
    }
    .contact-info p {
      color: var(--color-text-light);
      font-size: 0.95rem;
      line-height: 1.8;
      margin-bottom: 1rem;
    }
    .contact-detail {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.6rem;
      font-size: 0.92rem;
      color: var(--color-text-light);
    }
    .contact-detail-icon {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--color-white);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .contact-form {
      background: var(--color-white);
      padding: 2.5rem;
      border-radius: var(--radius-soft);
    }
    .form-group {
      margin-bottom: 1.2rem;
    }
    .form-group label {
      display: block;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--color-text);
      margin-bottom: 0.4rem;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--color-beige-dark);
      border-radius: 10px;
      font-family: var(--font-body);
      font-size: 0.92rem;
      color: var(--color-text);
      background: var(--color-cream);
      outline: none;
      transition: border var(--transition);
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--color-terracota);
    }
    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }
    .form-disclaimer {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      margin-bottom: 1.2rem;
      line-height: 1.6;
      padding: 0.75rem;
      background: rgba(196, 114, 90, 0.06);
      border-radius: 8px;
      border-left: 3px solid var(--color-terracota-light);
    }
    .form-submit {
      width: 100%;
      padding: 0.9rem;
      border: none;
      border-radius: var(--radius-pill);
      background: var(--color-terracota);
      color: var(--color-white);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: background var(--transition);
    }
    .form-submit:hover {
      background: var(--color-terracota-dark);
    }

    /* ============================================
       BANNER DE EMERGENCIAS PSICOLÓGICAS
    ============================================ */
    .emergency-banner {
      background: var(--color-beige);
      padding: 2rem 1.5rem;
      text-align: center;
      border-top: 1px solid var(--color-beige-dark);
    }
    .emergency-banner p {
      font-size: 0.85rem;
      color: var(--color-text-light);
      max-width: 700px;
      margin: 0 auto;
      line-height: 1.7;
    }
    .emergency-banner a {
      color: var(--color-terracota);
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .emergency-banner strong {
      color: var(--color-brown);
    }

    /* ============================================
       SECCIÓN 4 — FOOTER / SUSCRIPCIÓN
    ============================================ */
    .site-footer {
      background: var(--color-brown);
      color: rgba(255,255,255,0.75);
      padding: 4rem 1.5rem 2rem;
    }

    .footer-inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2.5rem;
      text-align: center;
    }

    .footer-brand .footer-logo {
      font-family: var(--font-display);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--color-white);
      margin-bottom: 0.5rem;
    }
    .footer-brand p {
      font-size: 0.88rem;
      max-width: 320px;
      margin: 0 auto;
      line-height: 1.7;
    }

    .footer-newsletter h3 {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--color-white);
      margin-bottom: 0.5rem;
    }
    .footer-newsletter p {
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }
    .newsletter-form {
      display: flex;
      gap: 0.5rem;
      max-width: 400px;
      margin: 0 auto;
    }
    .newsletter-form input[type="email"] {
      flex: 1;
      padding: 0.75rem 1.2rem;
      border-radius: var(--radius-pill);
      border: 1px solid rgba(255,255,255,0.2);
      background: rgba(255,255,255,0.08);
      color: var(--color-white);
      font-family: var(--font-body);
      font-size: 0.9rem;
      outline: none;
      transition: border var(--transition);
    }
    .newsletter-form input[type="email"]::placeholder {
      color: rgba(255,255,255,0.4);
    }
    .newsletter-form input[type="email"]:focus {
      border-color: var(--color-terracota-light);
    }
    .newsletter-form button {
      padding: 0.75rem 1.6rem;
      border-radius: var(--radius-pill);
      background: var(--color-terracota);
      color: var(--color-white);
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.88rem;
      border: none;
      cursor: pointer;
      transition: background var(--transition);
      white-space: nowrap;
    }
    .newsletter-form button:hover {
      background: var(--color-terracota-dark);
    }

    .footer-social {
      display: flex;
      justify-content: center;
      gap: 1rem;
    }
    .social-link {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.7);
      transition: background var(--transition), color var(--transition), border-color var(--transition);
    }
    .social-link:hover {
      background: var(--color-terracota);
      border-color: var(--color-terracota);
      color: var(--color-white);
    }

    .footer-bottom {
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      text-align: center;
    }
    .footer-legal {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-bottom: 1rem;
    }
    .footer-legal a {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
      transition: color var(--transition);
    }
    .footer-legal a:hover { color: var(--color-terracota-light); }
    .footer-copy {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.35);
    }

    /* ============================================
       COOKIE BANNER (RGPD)
    ============================================ */
    .cookie-banner {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background: var(--color-brown);
      color: rgba(255,255,255,0.85);
      padding: 1.2rem 1.5rem;
      z-index: 200;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      font-size: 0.85rem;
      box-shadow: 0 -4px 24px rgba(0,0,0,0.15);
      transform: translateY(0);
      transition: transform 0.4s var(--ease-out);
    }
    .cookie-banner.hidden { transform: translateY(100%); }
    .cookie-banner a {
      color: var(--color-terracota-light);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .cookie-accept {
